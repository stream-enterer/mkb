vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

direction: right

# ── Classes ──────────────────────────────────────────────

classes: {
  cat-actors: {
    style.fill: "#DCEEFB"
    style.stroke: "#1565C0"
    style.stroke-width: 2
    style.font-size: 28
    style.bold: true
    style.font-color: "#0D47A1"
    style.border-radius: 12
    style.shadow: true
    label.near: outside-top-center
  }
  cat-attributes: {
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
    style.stroke-width: 2
    style.font-size: 28
    style.bold: true
    style.font-color: "#BF360C"
    style.border-radius: 12
    style.shadow: true
    label.near: outside-top-center
  }
  cat-systems: {
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    style.stroke-width: 2
    style.font-size: 28
    style.bold: true
    style.font-color: "#1B5E20"
    style.border-radius: 12
    style.shadow: true
    label.near: outside-top-center
  }
  cat-space: {
    style.fill: "#F3E5F5"
    style.stroke: "#6A1B9A"
    style.stroke-width: 2
    style.font-size: 28
    style.bold: true
    style.font-color: "#4A148C"
    style.border-radius: 12
    style.shadow: true
    label.near: outside-top-center
  }

  # ── Per-category children (tinted to parent) ──

  child-actors: {
    style.fill: "#EBF4FC"
    style.stroke: "#7BADD4"
    style.stroke-width: 1
    style.font-size: 22
    style.font-color: "#1A3A5C"
    style.border-radius: 8
    width: 310
    height: 56
  }
  child-attributes: {
    style.fill: "#FEF6EE"
    style.stroke: "#D49A56"
    style.stroke-width: 1
    style.font-size: 22
    style.font-color: "#5C2E00"
    style.border-radius: 8
    width: 310
    height: 56
  }
  child-systems: {
    style.fill: "#EFF7F0"
    style.stroke: "#6DB06F"
    style.stroke-width: 1
    style.font-size: 22
    style.font-color: "#1A3D1C"
    style.border-radius: 8
    width: 310
    height: 56
  }
  child-space: {
    style.fill: "#F5EFF8"
    style.stroke: "#A068B8"
    style.stroke-width: 1
    style.font-size: 22
    style.font-color: "#3A1550"
    style.border-radius: 8
    width: 310
    height: 56
  }

  edge-style: {
    style.stroke-width: 2
    style.font-size: 16
    style.italic: true
    style.stroke-dash: 5
  }
}

# ── Title ────────────────────────────────────────────────

title: "AASS World Model\nActors — Attributes — Systems — Space" {
  near: top-center
  shape: text
  style.font-size: 36
  style.bold: true
  style.font-color: "#212121"
}

# ── ACTORS ───────────────────────────────────────────────

actors: ACTORS {
  class: cat-actors
  grid-rows: 2
  grid-columns: 3
  grid-gap: 24

  sovereign: Sovereign States { class: child-actors }
  intl-orgs: International Organizations { class: child-actors }
  sub-state: Sub-state Political Entities { class: child-actors }
  nsag: Non-state Armed Groups { class: child-actors }
  econ: Economic Actors { class: child-actors }
  trans: Transnational Networks { class: child-actors }
}

# ── ATTRIBUTES ───────────────────────────────────────────

attributes: ATTRIBUTES {
  class: cat-attributes
  grid-rows: 2
  grid-columns: 3
  grid-gap: 24

  capabilities: Capabilities / Assets { class: child-attributes }
  demographics: Demographics { class: child-attributes }
  political: Political Conditions { class: child-attributes }
  ideational: Ideational Attributes { class: child-attributes }
  economic: Economic Attributes { class: child-attributes }
  relational: Relational Attributes { class: child-attributes }
}

# ── SYSTEMS ──────────────────────────────────────────────

systems: SYSTEMS {
  class: cat-systems
  grid-rows: 2
  grid-columns: 3
  grid-gap: 24

  institutional: Institutional { class: child-systems }
  infrastructure: Infrastructure { class: child-systems }
  markets: Market / Exchange { class: child-systems }
  normative: Normative { class: child-systems }
  environmental: Environmental / Physical { class: child-systems }
}

# ── SPACE ────────────────────────────────────────────────

space: SPACE {
  class: cat-space
  grid-rows: 2
  grid-columns: 3
  grid-gap: 24

  phys: Physical Geography { class: child-space }
  pol: Political Geography { class: child-space }
  infra: Infrastructure Geography { class: child-space }
  info: Informational / Virtual Space { class: child-space }
  strategic: Strategic Domains { class: child-space }
}

# ── Interaction Edges ────────────────────────────────────

actors <-> attributes: "possess / constrain" {
  class: edge-style
  style.stroke: "#1565C0"
  style.font-color: "#1565C0"
}
actors <-> systems: "participate in / capture" {
  class: edge-style
  style.stroke: "#2E7D32"
  style.font-color: "#2E7D32"
}
actors <-> space: "occupy / contest" {
  class: edge-style
  style.stroke: "#6A1B9A"
  style.font-color: "#6A1B9A"
}
attributes <-> systems: "shape / determine" {
  class: edge-style
  style.stroke: "#E65100"
  style.font-color: "#E65100"
}
systems <-> space: "operate across / enabled by" {
  class: edge-style
  style.stroke: "#00695C"
  style.font-color: "#00695C"
}
attributes <-> space: "distributed across / located in" {
  class: edge-style
  style.stroke: "#AD1457"
  style.font-color: "#AD1457"
}
